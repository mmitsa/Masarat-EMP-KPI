{
    "Logging": {
        "LogLevel": {
            "Default": "Warning",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore": "Warning"
        }
    },
    "UseInMemoryDatabase": false,
    "ConnectionStrings": {
        "EPMConnection": "Host=${POSTGRES_HOST};Port=${POSTGRES_PORT};Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD};Pooling=true;Minimum Pool Size=25;Maximum Pool Size=200;Timeout=15;Command Timeout=30;Application Name=Masarat.EPM.API;"
    },
    "Database": {
        "Provider": "PostgreSQL",
        "InitializeMode": "Migrate"
    },
    "Redis": {
        "ConnectionString": "${REDIS_HOST}:6379,password=${REDIS_PASSWORD},abortConnect=false"
    },
    "Authentication": {
        "Authority": "http://localhost:5000",
        "Audience": "masarat-api"
    },
    "Cors": {
        "AllowedOrigins": [
            "https://unified.mmit.sa"
        ]
    },
    "RateLimiting": {
        "EnableRateLimiting": true,
        "PermitLimit": 100,
        "Window": 60
    },
    "Integrations": {
        "HR": {
            "BaseUrl": "${HR_SERVICE_URL}",
            "EmployeesEndpoint": "/api/hr/employees",
            "ApiKey": "${HR_INTEGRATION_API_KEY}"
        }
    },
    "_Note": "Kestrel endpoints removed - IIS manages port bindings in inprocess hosting mode"
}
