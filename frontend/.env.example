# =================================================================
# Unified Dashboard Environment Configuration
# =================================================================
# Copy this file to .env.local for development
# NEVER commit .env.local or .env.production to git!
# =================================================================

# =================================================================
# NextAuth Configuration (REQUIRED)
# =================================================================
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secure-random-secret-here-min-32-chars
NEXTAUTH_URL=http://localhost:3008

# =================================================================
# Authentication Mode
# =================================================================
# Set to your IdentityServer URL for production
# Leave empty or set to 'mock' to use mock authentication (development only)
AUTH_ISSUER=mock

# Mock Auth Password (DEVELOPMENT ONLY)
# Only used when AUTH_ISSUER=mock
# In production, this should NOT be set
MOCK_AUTH_PASSWORD=DevPassword123!

# =================================================================
# API Gateway Configuration
# =================================================================
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_IDENTITY_URL=http://localhost:5090

# =================================================================
# PostgreSQL Database (Primary)
# =================================================================
DATA_SOURCE_PRIMARY=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=masarat_modern
DB_USER=postgres
DB_PASSWORD=your-secure-postgres-password

# Sync to Postgres flag (for SQL Server primary mode)
SYNC_TO_POSTGRES=false

# =================================================================
# SQL Server Database (Optional/Legacy)
# =================================================================
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASS=your-secure-mssql-password
MSSQL_DATABASE=Masarat_HR
DB_NAME_HR=Masarat_HR

# =================================================================
# Redis Cache (Optional)
# =================================================================
REDIS_URL=redis://localhost:6379

# =================================================================
# AI Service Configuration (Optional)
# =================================================================
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000
DLLM_MODEL=GSAI-ML/Tiny-A2D-Qwen-0.5B
USE_GPU=true

# External AI API Keys (Optional)
# GROQ_API_KEY=your-groq-api-key
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# =================================================================
# Environment
# =================================================================
NODE_ENV=development
LOG_LEVEL=INFO

# =================================================================
# Feature Flags
# =================================================================
NEXT_PUBLIC_USE_PLATFORM_API=false
