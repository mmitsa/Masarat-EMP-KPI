# Masarat Unified Platform - Development Environment Variables
# Copy this file to .env.local for local development

# ============================================================================
# AUTHENTICATION (IdentityServer) - DEVELOPMENT
# ============================================================================
# Option 1: Use development IdentityServer
AUTH_ISSUER=https://identity-dev.masarat.sa

# Option 2: Use mock for local testing only (NOT for production)
# AUTH_ISSUER=mock

AUTH_CLIENT_ID=masarat.dashboard.dev
AUTH_CLIENT_SECRET=dev_secret_change_this

# ============================================================================
# NEXTAUTH CONFIGURATION - DEVELOPMENT
# ============================================================================
NEXTAUTH_URL=http://localhost:3008
NEXTAUTH_SECRET=development_secret_at_least_32_characters_long

# ============================================================================
# API GATEWAY - DEVELOPMENT
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
NODE_ENV=development

# ============================================================================
# DEVELOPMENT FEATURES
# ============================================================================
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DEV_TOOLS=true
LOG_LEVEL=debug

# ============================================================================
# FEATURE FLAGS - ALL ENABLED FOR TESTING
# ============================================================================
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
