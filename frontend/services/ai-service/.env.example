# =============================================================================
# AI Service Configuration
# =============================================================================

# Server Configuration
HOST=0.0.0.0
PORT=8000

# dLLM Model Configuration
DLLM_MODEL=GSAI-ML/Tiny-A2D-Qwen-0.5B
# Options:
# - GSAI-ML/Tiny-A2D-Qwen-0.5B (Fast, 0.5GB)
# - GSAI-ML/Tiny-A2D-LLaMA-0.6B (Fast, 0.6GB)
# - GSAI-ML/LLaDA-8B (Accurate, 8GB)
# - GSAI-ML/Dream-7B (Accurate, 7GB)

# GPU Configuration
USE_GPU=true

# Fallback API Keys (Optional)
# Groq (Free & Fast - Recommended)
GROQ_API_KEY=

# OpenAI (Paid)
OPENAI_API_KEY=

# Logging
LOG_LEVEL=INFO
